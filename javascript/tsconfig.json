{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "include": ["src", "test"],
  "compilerOptions": {
    "lib": ["es2024"],
    "target": "es2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "types": ["node", "mocha"],
    "declaration": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "strict": false,
    "noImplicitAny": true
  }
}
