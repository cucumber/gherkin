{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "include": ["src", "test"],
  "compilerOptions": {
    "lib": ["es2023"],
    "target": "es2022",
    "types": ["node", "mocha"],
    "resolveJsonModule": true,
    "declaration": true,
    "inlineSourceMap": true,
    "strict": false,
    "noImplicitAny": true
  }
}
