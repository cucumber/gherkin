#!/usr/bin/env bash
set -euf -o pipefail
DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

if [ ! -f "${DIR}/arguments.txt" ] || [ "${DIR}/class-path.txt" -nt "${DIR}/arguments.txt" ]; then
  DEPENDENCIES="$(cat "${DIR}/class-path.txt")"
  # The classpath separator is operating system dependent.
  # Use the same as generated by Maven.
  if [[ "$DEPENDENCIES" == *\;* ]]; then
    CLASSPATH_SEPARATOR=";"
  else
    CLASSPATH_SEPARATOR=":"
  fi
  echo "--class-path $DEPENDENCIES$CLASSPATH_SEPARATOR${DIR}/../target/classes$CLASSPATH_SEPARATOR${DIR}/../target/test-classes" >> "${DIR}/arguments.txt"
  >&2 cat ""${DIR}/arguments.txt""
fi

java "@${DIR}/arguments.txt" io.cucumber.gherkin.GenerateTokens $*
