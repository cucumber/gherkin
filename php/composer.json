{
    "name": "cucumber/gherkin",
    "description": "Gherkin parser",
    "author": "Cucumber Limited <cukes@googlegroups.com>",
    "license": "MIT",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Cucumber\\Gherkin\\": [
                "src/",
                "src-generated/"
            ]
        }
    },
    "require": {
        "php": "^8.4",
        "ext-mbstring": "*",
        "cucumber/messages": ">=31.0.0 <34"
    },
    "require-dev": {
        "vimeo/psalm": "6.16.1",
        "phpunit/phpunit": "13.2.1",
        "psalm/plugin-phpunit": "0.19.7",
        "friendsofphp/php-cs-fixer": "3.95.8"
    }
}
