@helper CallProduction(ProductionRule production)
{
    switch(production.Type) {
        case ProductionRuleType.Start:
                @:_startRule(context, RuleType.@Camel(production.RuleName));
            break;
        case ProductionRuleType.End:
                @:_endRule(context, RuleType.@Camel(production.RuleName));
            break;
        case ProductionRuleType.Process:
                @:_build(context, token);
            break;
    }
}
@helper HandleParserError(IEnumerable<string> expectedTokens, State state)
{<text>
    token.detach();
    final expectedTokens = <String>[
      @Raw(string.Join(",\n      ", expectedTokens.Select(t => "'" + t + "'")))@(",")
    ];
    final error = token.isEof
        ? UnexpectedEofException(token, expectedTokens)
        : UnexpectedTokenException(token, expectedTokens);

    if (stopAtFirstError) {
      throw error;
    }

    _addError(context, error);
    return @state.Id;
