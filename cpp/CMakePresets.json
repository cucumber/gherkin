{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21
    },
    "configurePresets": [
        {
            "name": "host",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/install",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "On",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "test",
            "inherits": "host",
            "cacheVariables": {
                "CUCUMBER_GHERKIN_BUILD_TESTS": "On"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "host",
            "configurePreset": "host"
        },
        {
            "name": "test",
            "configurePreset": "test"
        }
    ],
    "testPresets": [
        {
            "name": "test",
            "configurePreset": "test",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error"
            }
        }
    ],
    "workflowPresets": [
        {
            "name": "host",
            "steps": [
                {
                    "name": "host",
                    "type": "configure"
                },
                {
                    "name": "host",
                    "type": "build"
                }
            ]
        },
        {
            "name": "test",
            "steps": [
                {
                    "name": "test",
                    "type": "configure"
                },
                {
                    "name": "test",
                    "type": "build"
                },
                {
                    "name": "test",
                    "type": "test"
                }
            ]
        }
    ]
}
