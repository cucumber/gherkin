(46:1)Comment:/  # ── 2. ŞİRKET: Çalışan İşlemleri ─────────────/
(47:1)Empty://
(48:3)RuleLine:()İş Kuralı/Çalışan izin ve performans yönetimi/
(49:1)Empty://
(50:5)BackgroundLine:()Mevcut Durum//
(51:7)StepLine:(Context)Halihazırda /çalışan deneme süresini tamamlamıştır/
(52:7)StepLine:(Conjunction)Ve /çalışanın 15 gün yıllık izin hakkı bulunmaktadır/
(53:1)Empty://
(54:5)ScenarioLine:()Örnek/İzin talebi onay akışı/
(55:7)StepLine:(Context)Zaten /çalışan sistem üzerinden izin talebi oluşturmuştur/
(56:7)StepLine:(Action)Eğer ki /yönetici bu talebi onaylarsa/
(57:7)StepLine:(Outcome)O zaman /izin durumu "Onaylandı" statüsüne geçer/
(58:7)StepLine:(Conjunction)Ve /sistem çalışana bildirim gönderir/
(59:1)Empty://
(60:5)ScenarioLine:()Örnek/Onaylanan izin bordro entegrasyonu/
(61:7)StepLine:(Context)Zaten /çalışanın izin talebi onaylanmıştır/
(62:7)StepLine:(Action)Ne zaman /bordro sistemi günlük senkronizasyonu çalıştırırsa/
(63:7)StepLine:(Outcome)O zaman /izin bilgisi bordro kaydına yansır/
(64:7)StepLine:(Conjunction)Ayrıca /İK raporlama paneli güncellenir/
(65:1)Empty://
(66:5)ScenarioLine:()Örnek/Kritik proje döneminde izin kısıtlaması/
(67:7)StepLine:(Context)Mevcut /aktif bir kritik proje dönemi tanımlıdır/
(68:7)StepLine:(Action)Eğer /çalışan bu dönemde izin talebi oluşturursa/
(69:7)StepLine:(Outcome)O zaman /sistem uyarı mesajı gösterir/
(70:7)StepLine:(Conjunction)Fakat /çalışan yönetici onayı ile istisnai izin alabilir/
(71:1)Empty://
(72:5)ScenarioLine:()Örnek/Performans değerlendirme sonucu/
(73:7)StepLine:(Context)Biliniyor ki /çalışan tüm hedeflerini tamamlamıştır/
(74:7)StepLine:(Conjunction)Hem de /müşteri memnuniyet puanı yüzde 92 üzerindedir/
(75:7)StepLine:(Action)Eğer /dönem sonu değerlendirmesi yapılırsa/
(76:7)StepLine:(Outcome)Böylece /çalışan terfi havuzuna dahil edilir/
(77:1)Empty://
(78:5)ScenarioLine:()Örnek/Disiplin kaydının terfi üzerindeki etkisi/
(79:7)StepLine:(Context)Mevcut /çalışanın aktif bir disiplin kaydı bulunmaktadır/
(80:7)StepLine:(Action)Eğer /dönem sonu değerlendirmesi yapılırsa/
(81:7)StepLine:(Outcome)O zaman /çalışan terfi havuzuna dahil edilmez/
(82:7)StepLine:(Conjunction)Ancak /çalışan disiplin kararına itiraz edebilir/
(83:1)Empty://
