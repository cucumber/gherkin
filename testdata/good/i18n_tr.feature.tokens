(113:7)StepLine:(Context)Mevcut /sepet boş/
(114:7)StepLine:(Context)Sistemde /ürün stokta var/
(115:7)StepLine:(Action)Ne zaman /kullanıcı ürünü sepete eklerse/
(116:7)StepLine:(Outcome)O zaman /sepette 1 ürün görünür/
(117:7)StepLine:(Conjunction)Ve /sepet simgesinde adet göstergesi güncellenir/
(118:7)StepLine:(Conjunction)Aynı zamanda /sepet toplam tutarı hesaplanır/
(119:1)Empty://
