(144:1)Comment:/  # ── 5. GÜMRÜK: İthalat İşlemleri ─────────────/
(145:1)Empty://
(146:3)RuleLine:()Kaide/Gümrük beyanname işlem esasları/
(147:1)Empty://
(148:5)BackgroundLine:()Önkoşul//
(149:7)StepLine:(Context)Başlangıçta /gümrük bilgi sistemi çevrimiçidir/
(150:7)StepLine:(Conjunction)Ve /güncel döviz kurları sisteme yüklenmiştir/
(151:1)Empty://
(152:5)ScenarioLine:()Senaryo/Yüksek değerli ithalat kontrolü/
(153:7)StepLine:(Context)Önceden /ithalatçı firma beyanname düzenlemiştir/
(154:7)StepLine:(Conjunction)Ve /beyan edilen ürün bedeli 50.000 doların üzerindedir/
(155:7)StepLine:(Action)Ne zaman ki /gümrük müfettişi inceleme başlatırsa/
(156:7)StepLine:(Outcome)Buna binaen /müfettiş fatura asılları ve menşe belgesi talep eder/
(157:1)Empty://
(158:5)ScenarioLine:()Senaryo/Müfettişin ek süre tanıması/
(159:7)StepLine:(Context)Kabul edelim ki /müfettiş inceleme sırasında eksik belge tespit etmiştir/
(160:7)StepLine:(Action)Eğer /ithalatçı ek süre talep ederse/
(161:7)StepLine:(Outcome)O zaman /müfettiş 5 iş günü ek süre tanıyabilir/
(162:7)StepLine:(Conjunction)Lakin /bu süre bir defaya mahsus uygulanır/
(163:1)Empty://
(164:5)ScenarioLine:()Senaryo/Kısıtlı ürün ithalatı/
(165:7)StepLine:(Context)Kabul edelim ki /beyan edilen ürün kısıtlı mal listesindedir/
(166:7)StepLine:(Conjunction)Ve /ithalatçının özel izin belgesi bulunmamaktadır/
(167:7)StepLine:(Action)Eğer ki /gümrük kontrolünde bu durum tespit edilirse/
(168:7)StepLine:(Outcome)Sonuç olarak /ürün gümrükten geçiş izni alamaz/
(169:7)StepLine:(Conjunction)Ama /ithalatçı 10 iş günü içinde gerekli izni sunabilir/
(170:1)Empty://
(171:1)Comment:/  # ── 6. HUKUK: Hizmet Sözleşmesi ──────────────/
(172:1)Empty://
(173:3)RuleLine:()Hüküm/Hizmet alım sözleşmesi cezai şartları/
(174:1)Empty://
(175:5)BackgroundLine:()Mukaddime//
(176:7)StepLine:(Context)Farz edelim ki /taraflar arasında hizmet sözleşmesi akdedilmiştir/
(177:7)StepLine:(Conjunction)Ve /hizmet seviyesi taahhüdü yüzde 99.9 olarak belirlenmiştir/
(178:1)Empty://
(179:5)ScenarioLine:()Vaka/Gecikme cezası uygulaması/
(180:7)StepLine:(Context)Varsayalım ki /hizmet sağlayıcı işi teslim edememiştir/
(181:7)StepLine:(Conjunction)Ve /teslim süresi 15 takvim günü aşılmıştır/
(182:7)StepLine:(Action)Şayet /gecikme mücbir bir sebebe dayanmıyorsa/
(183:7)StepLine:(Outcome)Netice itibariyle /günlük yüzde 1 oranında gecikme cezası uygulanır/
(184:1)Empty://
(185:5)ScenarioLine:()Vaka/Mücbir sebep istisnası/
(186:7)StepLine:(Context)Varsayalım ki /teslim gecikmesi mücbir sebepten kaynaklanmıştır/
(187:7)StepLine:(Action)Eğer /hizmet sağlayıcı belgelendirme sunarsa/
(188:7)StepLine:(Outcome)O zaman /gecikme cezası uygulanmaz/
(189:7)StepLine:(Conjunction)Meğer ki /taraflar aksini kararlaştırmışsa/
(190:1)Empty://
(191:5)ScenarioLine:()Vaka/Gecikme nedeniyle fesih hakkı/
(192:7)StepLine:(Context)Zaten /hizmet sağlayıcıya gecikme cezası uygulanmıştır/
(193:7)StepLine:(Conjunction)Buna ek olarak /gecikme 30 takvim gününü aşmıştır/
(194:7)StepLine:(Action)Şayet /işveren sözleşmeyi feshetmek isterse/
(195:7)StepLine:(Outcome)Şu halde /tek taraflı fesih hakkını kullanabilir/
(196:1)Empty://
(197:5)ScenarioLine:()Vaka/Sözleşme yenileme müzakeresi/
(198:7)StepLine:(Context)Geçmişte /taraflar sözleşmeyi karşılıklı memnuniyetle yürütmüştür/
(199:7)StepLine:(Conjunction)Ve /sözleşmenin bitimine 60 gün kalmıştır/
(200:7)StepLine:(Action)Şayet /yeni dönem koşulları üzerinde uzlaşma sağlanırsa/
(201:7)StepLine:(Outcome)Bu durumda /sözleşme aynı koşullarla 1 yıl uzatılır/
(202:1)Empty://
(203:5)ScenarioLine:()Vaka/Uzlaşma sağlanamaması durumu/
(204:7)StepLine:(Context)Geçmişte /sözleşme yenileme müzakeresi başlatılmıştır/
(205:7)StepLine:(Conjunction)Ve /taraflar yeni koşullarda uzlaşma sağlayamamıştır/
(206:7)StepLine:(Action)Eğer /sözleşme süresi sona ererse/
(207:7)StepLine:(Conjunction)Buna mukabil /tasfiye süreci başlar/
(208:1)Empty://
(209:1)Comment:/  # ── 7. SAĞLIK: Acil Servis ────────────────────/
(210:1)Empty://
(211:3)RuleLine:()Kural/Acil servis triaj ve sevk prosedürü/
(212:1)Empty://
(213:5)BackgroundLine:()Geçmiş//
(214:7)StepLine:(Context)Diyelim ki /hastane acil servisi 7/24 hizmet vermektedir/
(215:7)StepLine:(Conjunction)Ve /triaj sistemi aktiftir/
(216:1)Empty://
(217:5)ScenarioLine:()Senaryo/Kritik hasta müdahalesi/
(218:7)StepLine:(Context)Diyelim ki /hasta acil servise başvurmuştur/
(219:7)StepLine:(Conjunction)Ve /triaj hemşiresi kırmızı kod belirlemiştir/
(220:7)StepLine:(Action)Eğer /müdahale odası müsaitse/
(221:7)StepLine:(Outcome)O zaman /hasta derhal müdahale odasına alınır/
(222:1)Empty://
(223:5)ScenarioLine:()Senaryo/Yoğun bakım kapasitesi dolu iken sevk/
(224:7)StepLine:(Context)Varsayılan olarak /hastanenin yoğun bakım kapasitesi 20 yataktır/
(225:7)StepLine:(Conjunction)Ve /mevcut doluluk oranı yüzde 100'dür/
(226:7)StepLine:(Action)Şayet /en yakın uygun hastane belirlenirse/
(227:7)StepLine:(Outcome)Bunun üzerine /hastane nakil işlemini başlatır/
(228:7)StepLine:(Conjunction)Ve /sistem hasta dosyasını karşı hastaneye aktarır/
(229:1)Empty://
(230:1)Comment:/  # ── 8. PERAKENDE: Sadakat Sistemi ─────────────/
(231:1)Empty://
(232:3)RuleLine:()İş Kuralı/Sadakat kartı ve puan kullanımı/
(233:1)Empty://
(234:5)BackgroundLine:()Önceki Durum//
(235:7)StepLine:(Context)Zaten /müşteri sadakat programına kayıtlıdır/
(236:7)StepLine:(Conjunction)Ve /kartında 500 puan birikmiştir/
(237:1)Empty://
(238:5)ScenarioLine:()Senaryo/Puan ile kısmi ödeme/
(239:7)StepLine:(Context)Mevcut /müşteri kasada ödeme aşamasındadır/
(240:7)StepLine:(Action)Eğer /müşteri ödemenin bir kısmını puanla yapmak isterse/
(241:7)StepLine:(Outcome)O zaman /puanlar toplam tutardan düşülür/
(242:7)StepLine:(Conjunction)Ve /kalan tutar diğer ödeme yöntemiyle tahsil edilir/
(243:7)StepLine:(Outcome)Beklenen /işlem fişinde puan indiriminin görülmesidir/
(244:1)Empty://
(245:5)ScenarioLine:()Senaryo/Yetersiz puan ile ödeme denemesi/
(246:7)StepLine:(Context)Mevcut /müşterinin puan bakiyesi sıfırdır/
(247:7)StepLine:(Action)Eğer /müşteri puanla ödeme yapmaya çalışırsa/
(248:7)StepLine:(Outcome)O zaman /sistem yetersiz puan uyarısı gösterir/
(249:1)Empty://
(250:5)ScenarioLine:()Senaryo/Yetersiz puan sonrası alternatif ödeme yönlendirmesi/
(251:7)StepLine:(Context)Zaten /müşterinin puan ile ödeme denemesi başarısız olmuştur/
(252:7)StepLine:(Action)Eğer /müşteri ödeme ekranında kalırsa/
(253:7)StepLine:(Outcome)O zaman /sistem müşteriyi farklı ödeme yöntemine yönlendirir/
(254:7)StepLine:(Conjunction)Aksi halde /müşteri sepet sayfasına geri döner/
