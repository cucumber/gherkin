(85:1)Empty://
(86:3)RuleLine:()Kural/Üretim hattı kalite ve güvenlik prosedürü/
(87:1)Empty://
(88:5)BackgroundLine:()Giriş//
(89:7)StepLine:(Context)Halihazırda /üretim hattı çalışır durumdadır/
(90:7)StepLine:(Conjunction)Ve /sensörler kalibre edilmiştir/
(91:7)StepLine:(Conjunction)Bir de /hata toleransı binde 2 olarak belirlenmiştir/
(92:1)Empty://
(93:5)ScenarioLine:()Durum/Hatalı ürün oranı eşik değeri aşımı/
(94:7)StepLine:(Context)Mevcut /üretim hattı saatte 500 birim üretir/
(95:7)StepLine:(Action)Ne zaman ki /sensör ardışık 5 hatalı ürün tespit ederse/
(96:7)StepLine:(Outcome)O zaman /üretim hattı otomatik olarak durur/
(97:7)StepLine:(Outcome)Bunun üzerine /sistem vardiya amirine ve kalite mühendisine bildirim gönderir/
(98:1)Empty://
(99:5)ScenarioLine:()Durum/Planlı bakım sürecinde hat duruşu/
(100:7)StepLine:(Context)Önceden /planlı bakım penceresi tanımlanmıştır/
(101:7)StepLine:(Action)Eğer /üretim hattı bakım süresi içinde durursa/
(102:7)StepLine:(Outcome)O zaman /otomatik alarm tetiklenmez/
(103:7)StepLine:(Conjunction)Yalnız /bakım süresi aşılırsa sistem uyarı üretir/
(104:1)Empty://
(105:5)ScenarioLine:()Durum/Ham madde stok seviyesi kritik eşik altında/
(106:7)StepLine:(Context)Önceden /belirlenen stok eşiği 2 günlük üretim kapasitesidir/
(107:7)StepLine:(Conjunction)Ve /mevcut alüminyum stoku bu eşiğin altına düşmüştür/
(108:7)StepLine:(Action)Eğer /üretim planında 3 günlük sipariş bekliyorsa/
(109:7)StepLine:(Outcome)O takdirde /satın alma birimine acil tedarik talebi iletilir/
(110:7)StepLine:(Conjunction)İlaveten /planlama birimi üretim planını yeniden önceliklendirir/
